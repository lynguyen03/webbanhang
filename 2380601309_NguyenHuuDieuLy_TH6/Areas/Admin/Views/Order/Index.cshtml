@model IEnumerable<_2380601309_NguyenHuuDieuLy_TH6.Models.Order>

@{
    ViewData["Title"] = "Quản Lý Đơn Hàng";
}

<div class="container mt-4">
    <h2>Quản Lý Đơn Hàng</h2>
    <hr />

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Mã ĐH</th>
                <th>Khách Hàng</th>
                <th>Số Điện Thoại</th>
                <th>Ngày Đặt</th>
                <th>Tổng Tiền</th>
                <th>Trạng Thái</th>
                <th>Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>#@order.Id</td>
                    <td>@order.CustomerName</td>
                    <td>@order.PhoneNumber</td>
                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@order.TotalAmount.ToString("N0") đ</td>
                    <td>
                        @if (order.Status == "Đã giao")
                        {
                            <span class="badge bg-success">Đã giao</span>
                        }
                        else if (order.Status == "Đang giao")
                        {
                            <span class="badge bg-primary">Đang giao</span>
                        }
                        else if (order.Status == "Đang xử lý")
                        {
                            <span class="badge bg-warning text-dark">Đang xử lý</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Đã hủy</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-info btn-sm text-white">Chi tiết</a>
                        <a asp-action="Edit" asp-route-id="@order.Id" class="btn btn-warning btn-sm">Cập nhật</a>
                        <a asp-action="Delete" asp-route-id="@order.Id" class="btn btn-danger btn-sm">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
