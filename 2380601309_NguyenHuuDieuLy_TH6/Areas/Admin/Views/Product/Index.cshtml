@model IEnumerable<_2380601309_NguyenHuuDieuLy_TH6.Models.Product>

@{
    ViewData["Title"] = "Quản Lý Sản Phẩm";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Quản Lý Sản Phẩm</h2>
        <a asp-area="Admin" asp-controller="Product" asp-action="Add" class="btn btn-success">
            + Thêm Sản Phẩm
        </a>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Hình Ảnh</th>
                <th>Tên Sản Phẩm</th>
                <th>Giá</th>
                <th>Mô Tả</th>
                <th>Danh Mục</th>
                <th>Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" alt="@product.Name" style="width:60px;height:60px;object-fit:cover;" />
                        }
                        else
                        {
                            <span class="text-muted">Không có ảnh</span>
                        }
                    </td>
                    <td>@product.Name</td>
                    <td>@product.Price.ToString("N0") đ</td>
                    <td>@product.Description</td>
                    <td>@product.Category?.Name</td>
                    <td>
                        <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@product.Id"
                           class="btn btn-warning btn-sm">Sửa</a>
                        <a asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@product.Id"
                           class="btn btn-danger btn-sm">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
