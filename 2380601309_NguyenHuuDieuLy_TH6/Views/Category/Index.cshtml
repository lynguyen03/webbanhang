@model IEnumerable<_2380601309_NguyenHuuDieuLy_TH6.Models.Category>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Danh Mục</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Add" class="btn btn-primary">
            ＋ Thêm Danh Mục
        </a>
    }
</div>

<div class="table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Tên Danh Mục</th>
                <th>Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td style="font-weight: 600; color: #FFFFFE;">@category.Name</td>
                    <td>
                        <div class="d-flex gap-2 flex-wrap">
                            <a asp-action="Display" asp-route-id="@category.Id" class="btn btn-success btn-sm">Chi Tiết</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Update" asp-route-id="@category.Id" class="btn btn-warning btn-sm">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-danger btn-sm">Xóa</a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
