@model _2380601309_NguyenHuuDieuLy_TH6.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Edit Product";
}

<div class="glass-card" style="max-width: 700px; margin: 0 auto;">
    <h2>Sửa Sản Phẩm</h2>

    <form asp-action="Update" method="post" enctype="multipart/form-data" style="margin-top: 1.5rem;">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImageUrl" />
        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Price"></label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="CategoryId">Danh Mục</label>
            <select asp-for="CategoryId" asp-items="@ViewBag.Categories"
                    class="form-control"></select>
        </div>
        <div class="form-group mb-3">
            <label for="ImageFile" class="form-label">Hình Ảnh Chính</label>
            <input type="file" name="ImageFile" id="ImageFile" class="form-control" />
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mt-3 p-2" style="background: rgba(255,255,255,0.03); border-radius: 8px; border: 1px solid rgba(255,255,255,0.08); display: inline-block;">
                    <img src="@Model.ImageUrl" alt="Product Image" style="max-width: 200px; border-radius: 6px;" />
                </div>
            }
        </div>
        <div class="form-group mb-3">
            <label for="ImageFiles" class="form-label">Hình Ảnh Phụ</label>
            <input type="file" name="ImageFiles" id="ImageFiles" class="form-control" multiple />
            @if (Model.Images != null && Model.Images.Count > 0)
            {
                <div class="mt-3 d-flex flex-wrap gap-2">
                    @foreach (var img in Model.Images)
                    {
                        <div style="background: rgba(255,255,255,0.03); border-radius: 8px; border: 1px solid rgba(255,255,255,0.08); padding: 4px;">
                            <img src="@img.Url" alt="Secondary Image" style="max-width: 80px; max-height: 80px; object-fit: cover; border-radius: 6px;" />
                        </div>
                    }
                </div>
            }
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Cập Nhật</button>
            <a asp-action="Index" class="btn btn-secondary">Quay Lại</a>
        </div>
    </form>
</div>