@model _2380601309_NguyenHuuDieuLy_TH6.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Add Product";
}

<div class="glass-card" style="max-width: 700px; margin: 0 auto;">
    <h2>Thêm Sản Phẩm</h2>

    <form asp-action="Add" method="post" enctype="multipart/form-data" style="margin-top: 1.5rem;">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Price"></label>
            <input asp-for="Price" class="form-control" placeholder="Nhập giá..." />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" class="form-control" placeholder="Nhập mô tả sản phẩm..."></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="CategoryId">Danh Mục</label>
            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control"></select>
        </div>
        <div class="form-group mb-3">
            <label for="ImageFile" class="form-label">Hình Ảnh Chính</label>
            <input type="file" name="ImageFile" id="ImageFile" class="form-control" />
        </div>
        <div class="form-group mb-3">
            <label for="ImageFiles" class="form-label">Hình Ảnh Phụ</label>
            <input type="file" name="ImageFiles" id="ImageFiles" class="form-control" multiple />
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Thêm Sản Phẩm</button>
            <a asp-action="Index" class="btn btn-secondary">Quay Lại</a>
        </div>
    </form>
</div>