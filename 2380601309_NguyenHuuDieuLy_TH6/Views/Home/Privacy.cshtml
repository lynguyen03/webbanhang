@{
    ViewData["Title"] = "Chính Sách";
}

<div class="page-header text-center mb-5">
    <h1 class="display-4 fw-bold" style="background: var(--gradient-1); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Chính Sách Khách Hàng</h1>
    <p class="text-muted">Chúng tôi cam kết mang lại trải nghiệm tốt nhất cho bạn</p>
</div>

<div class="row g-4 mt-3 mb-5" id="policies">
    <div class="col-md-4">
        <div class="glass-card h-100 text-center p-4">
            <div class="mb-3">
                <span class="fs-1" style="color: var(--primary-light);">🛡️</span>
            </div>
            <h4 class="text-white mb-3">Bảo mật thông tin</h4>
            <p class="text-secondary mb-0">Cam kết bảo vệ 100% dữ liệu cá nhân và lịch sử đọc sách của khách hàng theo chuẩn quốc tế.</p>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="glass-card h-100 text-center p-4">
            <div class="mb-3">
                <span class="fs-1" style="color: var(--accent-light);">💳</span>
            </div>
            <h4 class="text-white mb-3">Thanh toán đa dạng</h4>
            <p class="text-secondary mb-0">Hỗ trợ thanh toán qua thẻ tín dụng, Momo, ZaloPay và chuyển khoản ngân hàng nhanh chóng.</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="glass-card h-100 text-center p-4">
            <div class="mb-3">
                <span class="fs-1" style="color: var(--success);">🌟</span>
            </div>
            <h4 class="text-white mb-3">Đặc quyền VIP</h4>
            <p class="text-secondary mb-0">Khách hàng thành viên được giảm giá từ 10-30% cho mỗi đơn hàng và miễn phí giao hàng toàn quốc.</p>
        </div>
    </div>
</div>
