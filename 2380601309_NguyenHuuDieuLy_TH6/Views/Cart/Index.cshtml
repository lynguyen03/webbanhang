@model List<_2380601309_NguyenHuuDieuLy_TH6.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ Hàng";
    var cartTotal = (decimal)ViewBag.CartTotal;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🛒 Giỏ Hàng</h2>
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">
        ← Tiếp Tục Mua Sắm
    </a>
</div>

@if (Model == null || Model.Count == 0)
{
    <div class="glass-card" style="text-align: center; padding: 3rem 2rem;">
        <div style="font-size: 4rem; margin-bottom: 1rem;">🛒</div>
        <h3 style="color: #FFFFFE; margin-bottom: 0.5rem;">Giỏ hàng trống</h3>
        <p style="color: #A7A9BE; margin-bottom: 1.5rem;">Bạn chưa thêm sản phẩm nào vào giỏ hàng.</p>
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg">
            🛍️ Xem Sản Phẩm
        </a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Sản Phẩm</th>
                    <th>Tên</th>
                    <th>Đơn Giá</th>
                    <th>Số Lượng</th>
                    <th>Thành Tiền</th>
                    <th>Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.ProductName"
                                     style="width: 60px; height: 60px; object-fit: cover; border-radius: 10px; border: 1px solid rgba(255,255,255,0.1);" />
                            }
                            else
                            {
                                <div style="width: 60px; height: 60px; background: rgba(255,255,255,0.05); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #72748D;">
                                    📷
                                </div>
                            }
                        </td>
                        <td style="font-weight: 600; color: #FFFFFE;">
                            <a asp-controller="Product" asp-action="Display" asp-route-id="@item.ProductId"
                               style="color: #FFFFFE; text-decoration: none;">
                                @item.ProductName
                            </a>
                        </td>
                        <td style="color: #A7A9BE;">@item.Price.ToString("N0") ₫</td>
                        <td>
                            <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" style="display: inline-flex; align-items: center; gap: 6px;">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" name="quantity" value="@(item.Quantity - 1)" class="btn-qty">−</button>
                                <span class="qty-display">@item.Quantity</span>
                                <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="btn-qty">+</button>
                            </form>
                        </td>
                        <td style="font-weight: 700; color: #FF6B6B;">@item.Total.ToString("N0") ₫</td>
                        <td>
                            <form asp-controller="Cart" asp-action="Remove" method="post" style="display: inline;">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Cart Summary -->
    <div class="cart-summary">
        <div class="cart-summary-row">
            <span>Tổng số sản phẩm:</span>
            <span>@Model.Sum(i => i.Quantity) sản phẩm</span>
        </div>
        <div class="cart-summary-row cart-summary-total">
            <span>Tổng tiền:</span>
            <span>@cartTotal.ToString("N0") ₫</span>
        </div>
        <div class="cart-summary-actions">
            <form asp-controller="Cart" asp-action="Clear" method="post" style="display: inline;">
                <button type="submit" class="btn btn-outline-secondary">🗑️ Xóa Tất Cả</button>
            </form>
            <a asp-controller="Cart" asp-action="Checkout" class="btn btn-primary btn-lg">
                💳 Thanh Toán
            </a>
        </div>
    </div>
}

<style>
    .btn-qty {
        width: 32px;
        height: 32px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.05);
        color: #FFFFFE;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }

    .btn-qty:hover {
        background: rgba(108, 99, 255, 0.2);
        border-color: #6C63FF;
    }

    .qty-display {
        min-width: 30px;
        text-align: center;
        font-weight: 700;
        color: #FFFFFE;
        font-size: 0.95rem;
    }

    .cart-summary {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        padding: 1.5rem 2rem;
        margin-top: 1.5rem;
        max-width: 450px;
        margin-left: auto;
    }

    .cart-summary-row {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        color: #A7A9BE;
        font-size: 0.95rem;
    }

    .cart-summary-total {
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        margin-top: 0.5rem;
        padding-top: 1rem;
        font-size: 1.25rem;
        font-weight: 800;
        color: #FFFFFE;
    }

    .cart-summary-total span:last-child {
        background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .cart-summary-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.25rem;
        justify-content: flex-end;
    }
</style>
