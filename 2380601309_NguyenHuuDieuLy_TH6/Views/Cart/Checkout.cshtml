@model _2380601309_NguyenHuuDieuLy_TH6.Models.Order

@{
    ViewData["Title"] = "Thanh Toán";
    var cartTotal = (decimal)ViewBag.CartTotal;
}

<div class="row mt-4">
    <div class="col-md-7">
        <div class="card glass-card">
            <div class="card-body">
                <h3 class="card-title mb-4">Thông Tin Giao Hàng</h3>
                <form asp-action="Checkout" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="CustomerName" class="form-label">Họ và Tên</label>
                        <input asp-for="CustomerName" class="form-control" required placeholder="Nhập họ và tên người nhận" />
                        <span asp-validation-for="CustomerName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label">Số Điện Thoại</label>
                        <input asp-for="PhoneNumber" class="form-control" required placeholder="Nhập số điện thoại" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ShippingAddress" class="form-label">Địa Chỉ Giao Hàng</label>
                        <textarea asp-for="ShippingAddress" class="form-control" rows="3" required placeholder="Nhập địa chỉ nhận hàng chi tiết"></textarea>
                        <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">Xác Nhận Đặt Hàng</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại Giỏ hàng</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-5 mt-4 mt-md-0">
        <div class="card glass-card">
            <div class="card-body">
                <h4 class="card-title mb-4">Tóm Tắt Đơn Hàng</h4>
                <div class="d-flex justify-content-between mb-2">
                    <span style="color: #A7A9BE;">Tổng Tiền:</span>
                    <span style="font-weight: 700; color: #FFFFFE;">@cartTotal.ToString("N0") ₫</span>
                </div>
                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                    <span style="color: #A7A9BE;">Phí Vận Chuyển:</span>
                    <span style="font-weight: 700; color: #2ECC71;">Miễn Phí</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span style="font-size: 1.1rem; font-weight: 700;">Thành Tiền:</span>
                    <span style="font-size: 1.5rem; font-weight: 800; background: linear-gradient(135deg, #FF6B6B, #FF8E8E); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
                        @cartTotal.ToString("N0") ₫
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
